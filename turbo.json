{
    "$schema": "https://turborepo.dev/schema.json",
    "ui": "tui",
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**", "next/**"],
            "cache": true
        },
        "dev": {
            "dependsOn": ["^build"],
            "persistent": true,
            "cache": false
        }
    }
}